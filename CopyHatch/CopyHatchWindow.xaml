<Window x:Class="VinTed.CopyHatch.CopyHatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:ThemeManager.RequestedTheme="Light"
        Title="VinTed — Copy Hatch Pattern"
        Width="450" Height="450"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- ModernWpf Theme (Light) -->
                <ui:ThemeResources RequestedTheme="Light"/>
                <ui:XamlControlsResources/>
                <!-- VinTed Shared Theme -->
                <ResourceDictionary Source="/VinTed;component/Themes/ThemeColors.xaml"/>
                <ResourceDictionary Source="/VinTed;component/Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource VtBgPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,18,24,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#005DA6" Offset="0"/>
                    <GradientStop Color="#0078D4" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="Copy Hatch Pattern" FontSize="17" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,4"/>
                <TextBlock Text="Sao chép pattern mặt cắt từ chi tiết mẫu sang chi tiết đích"
                           FontSize="11.5" Foreground="#CCE0F0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Instructions Card -->
        <Border Grid.Row="1" Margin="24,14,24,0"
                Background="{StaticResource VtBgCard}"
                BorderBrush="{StaticResource VtBorderLight}"
                BorderThickness="1" CornerRadius="6"
                Padding="18,14">
            <StackPanel>
                <TextBlock Text="HƯỚNG DẪN SỬ DỤNG" Style="{StaticResource VtSectionLabel}" Margin="0,0,0,10"/>

                <!-- Step 1 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="{StaticResource VtAccentPrimary}" Margin="0,0,10,0">
                        <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Chọn một CẠNH của chi tiết MẪU (Source)" FontSize="12"
                               Foreground="{StaticResource VtFgPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step 2 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="{StaticResource VtAccentSuccess}" Margin="0,0,10,0">
                        <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Chọn CẠNH chi tiết ĐÍCH (lặp lại nhiều lần)" FontSize="12"
                               Foreground="{StaticResource VtFgPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step 3 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="{StaticResource VtAccentWarning}" Margin="0,0,10,0">
                        <TextBlock Text="3" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Nhấn ESC để kết thúc" FontSize="12"
                               Foreground="{StaticResource VtFgPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Counter -->
                <Border Margin="0,12,0,0" Background="#EBF5FF" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource VtAccentPrimary}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="lblCount" Text="Đã copy: 0 hatch" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{StaticResource VtAccentPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Start Button -->
        <Border Grid.Row="2" Margin="24,14,24,0">
            <Button x:Name="btnStart" Content="▶  Bắt đầu Copy Hatch"
                    Click="BtnStart_Click" Style="{StaticResource VtBtnPrimary}"
                    FontSize="13"/>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Style="{StaticResource VtStatusBar}" Margin="0,14,0,0">
            <TextBlock x:Name="lblStatus"
                       Text="Chỉ hoạt động trong Drawing có Section View"
                       Style="{StaticResource VtStatusText}"/>
        </Border>
    </Grid>
</Window>
