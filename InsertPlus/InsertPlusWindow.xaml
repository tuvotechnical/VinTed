<Window x:Class="VinTed.InsertPlus.InsertPlusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:ThemeManager.RequestedTheme="Light"
        Title="VinTed — Insert Plus"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources RequestedTheme="Light"/>
                <ui:XamlControlsResources/>
                <ResourceDictionary Source="/VinTed;component/Themes/ThemeColors.xaml"/>
                <ResourceDictionary Source="/VinTed;component/Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource VtBgPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource VtBgCard}" 
                BorderBrush="{StaticResource VtBorderLight}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel>
                <TextBlock Text="CẤU HÌNH RÀNG BUỘC" Style="{StaticResource VtSectionLabel}" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <TextBlock Text="Offset (mm)" FontSize="12" Foreground="{StaticResource VtFgSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtOffset" Text="0.0" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Solution" FontSize="12" Foreground="{StaticResource VtFgSecondary}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbOpposed" Content="Opposed" IsChecked="True" Margin="0,0,12,0"/>
                            <RadioButton x:Name="rbAligned" Content="Aligned"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="chkLockRotation" Content="Lock Rotation" IsChecked="True" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Logic -->
        <StackPanel Grid.Row="1" Margin="24,20,24,24">
            
            <!-- Step 1: Source -->
            <TextBlock Text="BƯỚC 1: CHỌN NGUỒN" Style="{StaticResource VtSectionLabel}" Margin="0,0,0,12"/>
            <Button x:Name="btnSelectSource" HorizontalAlignment="Stretch" Click="BtnSelectSource_Click" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M11 2v2.07A8 8 0 0 0 4.07 11H2v2h2.07A8 8 0 0 0 11 19.93V22h2v-2.07A8 8 0 0 0 19.93 13H22v-2h-2.07A8 8 0 0 0 13 4.07V2m-2 4.08V8h2V6.09c2.5.41 4.5 2.41 4.92 4.91H16v2h1.91c-.41 2.5-2.41 4.5-4.91 4.92V16h-2v1.91C8.5 17.5 6.5 15.5 6.08 13H8v-2H6.09C6.5 8.5 8.5 6.5 11 6.08M12 11a1 1 0 0 0-1 1a1 1 0 0 0 1 1a1 1 0 0 0 1-1a1 1 0 0 0-1-1"
                          Fill="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="1. Chọn Cạnh Bu-lông mẫu" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="txtSourceInfo" Text="Chưa chọn đối tượng" 
                       FontSize="12" Foreground="{StaticResource VtFgMuted}" 
                       TextWrapping="Wrap" Margin="4,0,0,16"/>
            
            <CheckBox x:Name="chkIncludeHardware" Content="Copy kèm Vòng đệm / Đai ốc (Auto-detect)" 
                      IsChecked="True" Margin="0,0,0,24" FontSize="12" ToolTip="Tự động tìm và copy các chi tiết khác đang bị ràng buộc vào bu-lông này"/>

            <!-- Step 2: Target -->
            <TextBlock Text="BƯỚC 2: CHỌN ĐÍCH" Style="{StaticResource VtSectionLabel}" Margin="0,0,0,12"/>
            
            <Button x:Name="btnManualAttach" HorizontalAlignment="Stretch" Click="BtnManualAttach_Click" Style="{StaticResource VtBtnPrimary}" Margin="0,0,0,12" IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M10.76 8.69a.76.76 0 0 0-.76.76V20.9c0 .42.34.76.76.76c.19 0 .35-.06.48-.16l1.91-1.55l1.66 3.62c.13.27.4.43.69.43c.11 0 .22 0 .33-.08l2.76-1.28c.38-.18.56-.64.36-1.01L17.28 18l2.41-.45a.9.9 0 0 0 .43-.26c.27-.32.23-.79-.12-1.08l-8.74-7.35l-.01.01a.76.76 0 0 0-.49-.18M15 10V8h5v2zm-1.17-5.24l2.83-2.83l1.41 1.41l-2.83 2.83zM10 0h2v5h-2zM3.93 14.66l2.83-2.83l1.41 1.41l-2.83 2.83zm0-11.32l1.41-1.41l2.83 2.83l-1.41 1.41zM7 10H2V8h5z"
                          Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="2A. Copy thủ công (Chọn từng lỗ)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
                    
            <Button x:Name="btnAutoAttach" HorizontalAlignment="Stretch" Click="BtnAutoAttach_Click" Style="{StaticResource VtBtnSuccess}" IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M11 15H6l7-14v8h5l-7 14z"
                          Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="2B. Copy tự động (Fill toàn mặt phẳng)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock Text="Click 1 lỗ mẫu, hệ thống tự điền các lỗ giống nhau trên mặt đó." 
                       FontSize="11" Foreground="{StaticResource VtFgMuted}" 
                       TextWrapping="Wrap" Margin="4,4,0,0"/>
        </StackPanel>

    </Grid>
</Window>
