<Window x:Class="VinTed.Updater.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:ThemeManager.RequestedTheme="Light"
        Title="VinTed — Cập nhật"
        Width="480" Height="420"
        MinWidth="420" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        Background="#F5F6F7">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VinTed;component/Themes/ThemeColors.xaml"/>
                <ResourceDictionary Source="/VinTed;component/Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Local styles -->
            <Style x:Key="VersionLabelStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#666666"/>
            </Style>

            <Style x:Key="VersionValueStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Background="#005DA6" Padding="24,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Update Icon -->
                    <Path Data="M6.5 20q-2.28 0-3.89-1.57Q1 16.85 1 14.58q0-1.95 1.17-3.48q1.18-1.53 3.08-1.95q.58-2.02 2.14-3.4Q8.95 4.38 11 4.08v8.07L9.4 10.6L8 12l4 4l4-4l-1.4-1.4l-1.6 1.55V4.08q2.58.35 4.29 2.31T19 11q1.73.2 2.86 1.5q1.14 1.28 1.14 3q0 1.88-1.31 3.19T18.5 20Z"
                          Fill="White" Stretch="Uniform" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Phiên bản mới có sẵn!" FontFamily="Segoe UI"
                                   FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubHeader" Text="VinTed đã có bản cập nhật mới"
                                   FontFamily="Segoe UI" FontSize="13" Foreground="#CCDDEE" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Version Comparison -->
        <Border Grid.Row="1" Background="White" Margin="20,16,20,0" Padding="16"
                CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Version -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Phiên bản hiện tại" Style="{StaticResource VersionLabelStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtCurrentVersion" Text="1.0.0"
                               Style="{StaticResource VersionValueStyle}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Arrow -->
                <Path Grid.Column="1" Data="M4 11v2h12l-5.5 5.5l1.42 1.42L19.84 12l-7.92-7.92L10.5 5.5L16 11z"
                      Fill="#005DA6" Stretch="Uniform" Width="20" Height="20" Margin="16,0" VerticalAlignment="Center"/>

                <!-- New Version -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Phiên bản mới" Style="{StaticResource VersionLabelStyle}"
                               HorizontalAlignment="Center"/>
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8,2" Margin="0,4,0,0"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtLatestVersion" Text="1.1.0"
                                   FontFamily="Segoe UI Semibold" FontSize="14"
                                   Foreground="#2E7D32" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Release Notes -->
        <Border Grid.Row="2" Background="White" Margin="20,12,20,0" Padding="16"
                CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Nội dung cập nhật"
                           FontFamily="Segoe UI Semibold" FontSize="13"
                           Foreground="#333333" Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtReleaseNotes" TextWrapping="Wrap"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#555555" LineHeight="20"
                               Text="Đang tải thông tin..."/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Skip Checkbox -->
        <CheckBox Grid.Row="3" x:Name="ChkSkipVersion"
                  Content="Không nhắc lại cho phiên bản này"
                  FontFamily="Segoe UI" FontSize="12" Foreground="#888888"
                  Margin="24,12,24,0"/>

        <!-- Action Buttons -->
        <Grid Grid.Row="4" Margin="20,12,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BtnSkip" Content="Bỏ qua"
                    Click="BtnSkip_Click" Height="36"
                    HorizontalAlignment="Stretch"
                    FontFamily="Segoe UI" FontSize="14"
                    Background="#F0F0F0" Foreground="#333333"
                    BorderBrush="#CCCCCC" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="2" x:Name="BtnDownload" Click="BtnDownload_Click" Height="36"
                    HorizontalAlignment="Stretch" FontFamily="Segoe UI Semibold" FontSize="14"
                    Background="#005DA6" Foreground="White" BorderBrush="#004A85" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <Path Data="M5 20h14v-2H5m14-9h-4V3H9v6H5l7 7z" Fill="White" Stretch="Uniform" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Tải về ngay" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
